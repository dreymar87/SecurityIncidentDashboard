# ─── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=security_dashboard
DB_USER=postgres
DB_PASSWORD=changeme_strong_password
DB_SSL=false

# ─── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ENABLE_SCHEDULER=true

# ─── API Keys ──────────────────────────────────────────────
# NVD (free, increases rate limit from 5 to 50 req/30s)
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Have I Been Pwned (free for breach list endpoint)
# Register at: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# GreyNoise (free community tier — 100 req/day)
# Register at: https://www.greynoise.io/plans/community
GREYNOISE_API_KEY=

# Shodan (paid — optional, omit to skip Shodan sync)
# Register at: https://account.shodan.io/
SHODAN_API_KEY=

# Censys (free research tier — 250 req/month)
# Register at: https://search.censys.io/account
CENSYS_API_ID=
CENSYS_API_SECRET=
