# ─── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=security_dashboard
DB_USER=postgres
DB_PASSWORD=changeme_strong_password
DB_SSL=false

# ─── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ENABLE_SCHEDULER=true

# ─── API Keys ──────────────────────────────────────────────
# NVD (free, increases rate limit from 5 to 50 req/30s)
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Have I Been Pwned (free for breach list endpoint)
# Register at: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# GreyNoise (free community tier — 100 req/day)
# Register at: https://www.greynoise.io/plans/community
GREYNOISE_API_KEY=

# GitHub (free personal access token — used for GitHub Advisory DB sync)
# Generate at: https://github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=

# Shodan (optional — enables IP enrichment in Threat Intelligence)
# Register at: https://developer.shodan.io/
SHODAN_API_KEY=

# Censys (optional — enables IP enrichment in Threat Intelligence)
# Register at: https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# ─── MFA ───────────────────────────────────────────────────
# AES-256-GCM key for encrypting TOTP secrets at rest.
# Generate with: openssl rand -hex 32
# If unset, TOTP secrets are stored unencrypted (development only — set in production).
TOTP_ENCRYPTION_KEY=

# ─── Authentication ─────────────────────────────────────────
# Set to true in production to enforce login for admin operations
ENABLE_AUTH=true
# Required when ENABLE_AUTH=true in production — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-strong-random-value

# Bootstrap initial admin user — only used if the users table is empty at startup
# Leave blank (or remove) once an admin user exists
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Set to true only when serving over HTTPS
COOKIE_SECURE=false

# ─── SMTP (optional — for email notification channels) ───────
# Leave blank if you only use Slack/Teams/PagerDuty channels
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
